# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / Vite
node_modules/
dist/
.cache/
.npm/
.vite/

# Environments
.env
.venv/

# OS
.DS_Store
Thumbs.db

# Build
build/
release/
*.tar.gz

# SQLite databases (V6 persistence)
*.db
*.db-shm
*.db-wal

# ─── Generated experimental artefacts ────────────────────────────────────────
# Colonies and replays are large (>30MB total). Regenerate with:
#   python3 swarm_v5.py --headless --ticks 10000 --save colonies/v55_10k.json
colonies/*.json
!colonies/.gitkeep

# Experiment outputs. Regenerate with experiments/* scripts.
results/*.csv
results/*.json
results/*.txt
results/*.md
results/*.tex
results/figures/
!results/.gitkeep
# Keep curated/baseline reports if any are checked in explicitly via -f.

# Generated examples
results/example_*/
results/smoke_*/

# Nested ad-hoc result files; curated phase artifacts may be force-added.
results/**/*.tmp
results/**/*.log

# Per-run output folders (Phase 0.2 convention)
runs/

# Local paper drafts (Phase R7)
paper/*.tex
paper/*.aux
paper/*.log
paper/*.out
paper/*.toc
paper/*.bbl
paper/*.blg
paper/build/
